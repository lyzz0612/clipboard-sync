{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "clipboard-sync",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-30",
  "assets": {
    "directory": "public"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "clipboard-sync",
      "database_id": "${D1_DATABASE_ID}",
      "migrations_dir": "migrations"
    }
  ]
}
