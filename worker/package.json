{
  "name": "clipboard-sync-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0",
    "deploy": "node scripts/run-with-d1-config.mjs deploy --keep-vars",
    "check": "node scripts/run-with-d1-config.mjs deploy --dry-run",
    "db:migrate:local": "wrangler d1 migrations apply clipboard-sync --local",
    "db:migrate:remote": "node scripts/run-with-d1-config.mjs d1 migrations apply clipboard-sync --remote",
    "test": "node scripts/smoke-test.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260329.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.78.0"
  }
}
